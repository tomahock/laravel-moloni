{
    "name": "tomahock/laravel-moloni",
    "description": "Laravel package for integrating with the Moloni API",
    "type": "library",
    "keywords": ["laravel", "moloni", "api", "invoicing", "billing", "portugal"],
    "homepage": "https://github.com/tomahock/laravel-moloni",
    "license": "MIT",
    "authors": [
        {
            "name": "Tomahock",
            "email": "eu@tomahock.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Tomahock\\Moloni\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tomahock\\Moloni\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tomahock\\Moloni\\MoloniServiceProvider"
            ],
            "aliases": {
                "Moloni": "Tomahock\\Moloni\\Facades\\Moloni"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
